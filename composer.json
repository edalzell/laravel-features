{
    "name": "edalzell/laravel-features",
    "description": "Self-contained feature modules for Laravel with auto-registration of routes, migrations, views, events, and seeders",
    "license": "MIT",
    "keywords": [
        "Erin Dalzell",
        "laravel",
        "laravel-features"
    ],
    "authors": [
        {
            "name": "Erin Dalzell",
            "email": "erin@silentz.co",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/edalzell/laravel-features",
    "require": {
        "php": "^8.3",
        "composer/composer": "^2.8",
        "edalzell/laravel-features-plugin": "^0.1",
        "illuminate/contracts": "^12.0 || ^13.0"
    },
    "require-dev": {
        "brain/monkey": "^2.7",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "spatie/laravel-ray": "^1.40"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Edalzell\\Features\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Edalzell\\Features\\Tests\\": "tests/",
            "Edalzell\\Features\\Tests\\Fixtures\\": "tests/__fixtures__/"
        }
    },
    "config": {
        "allow-plugins": {
            "edalzell/laravel-features-plugin": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        },
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Edalzell\\Features\\ServiceProvider"
            ]
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "test": [
            "@composer run test:isolated",
            "@composer run test:default"
        ],
        "test:isolated": "vendor/bin/pest --testsuite=Isolated",
        "test:default": "vendor/bin/pest --testsuite=Default",
        "test-coverage": "vendor/bin/pest --coverage"
    }
}
